@page "/player/games"
@attribute [Authorize]
@inject IBoardLibraryApiClient ApiClient

<PageTitle>My Games</PageTitle>

<section class="space-y-6">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
            <h1 class="mt-4 app-page-title">My Games</h1>
            <p class="mt-4 max-w-3xl text-base leading-8 text-slate-300">
                Your library titles will appear here.
            </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row">
            <a class="rounded-full bg-cyan-300 px-5 py-3 text-center text-sm font-bold uppercase tracking-[0.18em] text-slate-950" href="/games">Browse Games</a>
            <a class="rounded-full border border-white/15 px-5 py-3 text-center text-sm font-semibold uppercase tracking-[0.18em] text-slate-100" href="/player/wishlist">Open wishlist</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <section class="app-panel p-6">
            <h2 class="text-xl font-semibold text-white">Player library unavailable</h2>
            <p class="mt-3 text-sm leading-7 text-slate-300">@ErrorMessage</p>
        </section>
    }
    else if (CurrentUser is null || EnrollmentState is null)
    {
        <section class="app-panel p-6">
            <div class="h-8 w-48 animate-pulse rounded-full bg-white/10"></div>
            <div class="mt-4 h-48 animate-pulse rounded-[1.75rem] bg-white/10"></div>
        </section>
    }
    else
    {
        <section class="grid gap-4 lg:grid-cols-[1.1fr_0.9fr]">
            <section class="app-panel p-6">
                <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Signed in as</div>
                <h2 class="mt-3 text-2xl font-semibold text-white">@CurrentUser.DisplayName</h2>
                <div class="mt-3 text-sm text-slate-300">@CurrentUser.Email</div>
                <div class="mt-6 grid gap-3 sm:grid-cols-2">
                    <div class="rounded-[1.25rem] bg-black/15 p-4">
                        <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Player access</div>
                        <div class="mt-2 text-lg font-semibold text-white">Active</div>
                        <div class="mt-2 text-sm text-slate-300">Ready to browse and manage your library.</div>
                    </div>
                    <div class="rounded-[1.25rem] bg-black/15 p-4">
                        <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Developer access</div>
                        <div class="mt-2 text-lg font-semibold text-white">@EnrollmentState.ToStatusLabel()</div>
                        <div class="mt-2 text-sm text-slate-300">@EnrollmentState.ToStatusDescription()</div>
                    </div>
                </div>
            </section>

            <section class="app-panel p-6">
                <div class="text-xs uppercase tracking-[0.22em] text-cyan-100/70">Library</div>
                <h2 class="mt-3 text-2xl font-semibold text-white">No games yet</h2>
                <p class="mt-3 text-sm leading-7 text-slate-300">
                    When you add games, they will show up here for quick access.
                </p>
            </section>
        </section>
    }
</section>

@code {
    private CurrentUserResponse? CurrentUser { get; set; }

    private DeveloperEnrollment? EnrollmentState { get; set; }

    private string? ErrorMessage { get; set; }

    protected override async Task OnInitializedAsync()
    {
        ErrorMessage = null;

        try
        {
            CurrentUser = await ApiClient.GetCurrentUserAsync();
            EnrollmentState = (await ApiClient.GetDeveloperEnrollmentAsync()).DeveloperEnrollment;

            if (CurrentUser is null)
            {
                ErrorMessage = "Your profile could not be loaded.";
            }
        }
        catch (Exception exception)
        {
            ErrorMessage = exception.Message;
        }
    }
}
